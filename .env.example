# 数字人平台配置文件示例
# 复制此文件为 .env 并填入实际的配置值
# cp .env.example .env

# ==================== LLM 配置 ====================
# 使用 OpenAI 兼容 API
LLM_MODEL=mimo-v2-flash
OPEN_AI_URL=https://api.xiaomimimo.com/v1
OPEN_AI_API_KEY=your_openai_api_key_here

# ==================== TTS 配置 ====================
# 可选: edge, doubao, tencent, azure, fish, sovits, cosyvoice, indextts2, xtts
TTS_TYPE=edge

# --- Edge TTS (免费，无需配置) ---
COSYVOICE_MODEL=CosyVoice-300M-SFT
COSYVOICE_VOICE=中文女

EDGE_TTS_VOICE=zh-CN-YunxiNeural

# --- 豆包TTS (需要有效的Access Token) ---
DOUBAO_APPID=your_doubao_appid
DOUBAO_ACCESS_TOKEN=your_doubao_access_token
DOUBAO_SECRET_KEY=your_doubao_secret_key
DOUBAO_TOKEN=your_doubao_token
DOUBAO_RESOURCE_ID=seed-tts-1.0
DOUBAO_VOICE_ID=zh_female_tianxinxiaomei_emo_v2_mars_bigtts

# --- 腾讯TTS (需要配置) ---
TENCENT_APPID=your_tencent_appid
TENCENT_SECRET_ID=your_tencent_secret_id
TENCENT_SECRET_KEY=your_tencent_secret_key
TENCENT_VOICE_TYPE=1001

# --- Azure TTS (需要配置) ---
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_TTS_REGION=your_azure_region

# --- 本地TTS服务 (需要启动服务器) ---
TTS_SERVER=http://127.0.0.1:9880

# ==================== ASR 配置 (默认: 腾讯ASR) ====================
# 可选: tencent, funasr, huber, lip
ASR_TYPE=tencent

# --- 腾讯ASR (默认) ---
TENCENT_APPID=your_tencent_appid
TENCENT_ASR_SECRET_ID=your_tencent_secret_id
TENCENT_ASR_SECRET_KEY=your_tencent_secret_key

# ==================== 其他配置 ====================
FPS=25
LOG_LEVEL=INFO

# ==================== 可选配置 ====================
# Face Alignment (Optional)
# FACEALIGNMENT_USERDIR=

# 最大会话数
MAX_SESSION=5

# Web监听端口
LISTEN_PORT=8000

# 音频处理
AUDIO_HQ_PROCESSOR=1      # 启用高质量处理器
AUDIO_CROSSFADE=64        # 交叉淡入样本数
AUDIO_CUTOFF=6000.0       # 低通截止频率
