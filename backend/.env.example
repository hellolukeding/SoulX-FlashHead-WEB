# ===========================================
# 数字人平台 - 环境变量配置
# ===========================================

# -------------------------------------------
# LLM 配置（必需）
# -------------------------------------------
# 阿里云通义千问 API Key
# 获取地址: https://dashscope.aliyuncs.com/api-key
OPEN_AI_API_KEY=your-dashscope-api-key-here

# API 基础 URL（使用阿里云通义千问兼容模式）
OPEN_AI_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# LLM 模型名称
# 可选值: qwen-plus, qwen-turbo, qwen-max
LLM_MODEL=qwen-plus

# -------------------------------------------
# TTS 配置
# -------------------------------------------
# TTS 类型: cosyvoice, edge, doubao, tencent
TTS_TYPE=cosyvoice

# CosyVoice 配置
COSYVOICE_MODEL_PATH=/opt/digital-human-platform/models/CosyVoice

# -------------------------------------------
# ASR 配置
# -------------------------------------------
# ASR 类型: tencent, wav2vec
ASR_TYPE=tencent

# 腾讯云 ASR 配置（如果使用腾讯 ASR）
TENCENT_ASR_APP_ID=your-app-id
TENCENT_ASR_SECRET_ID=your-secret-id
TENCENT_ASR_SECRET_KEY=your-secret-key

# -------------------------------------------
# 其他配置
# -------------------------------------------
# 服务器端口
PORT=8000

# 日志级别
LOG_LEVEL=INFO
