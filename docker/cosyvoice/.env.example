# CosyVoice TTS 服务 - 环境变量配置

# 服务端口
COSYVOICE_PORT=8002

# CosyVoice 模型根目录 (包含 CosyVoice 源代码和预训练模型)
COSYVOICE_ROOT=/opt/digital-human-platform/models/CosyVoice

# 自定义资源目录 (可选，用于存放自定义参考音频)
COSYVOICE_ASSETS=./assets

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ModelScope 缓存目录 (通常在 COSYVOICE_ROOT/pretrained_models 下)
# MODELSCOPE_CACHE_DIR=/opt/digital-human-platform/models/CosyVoice/pretrained_models

# GPU 设备 (留空使用所有可用 GPU)
# CUDA_VISIBLE_DEVICES=0
